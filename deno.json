{
  "name": "@pixel/pptx",
  "version": "0.8.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts"
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "fflate": "npm:fflate@0.8.2",
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "check": "deno check mod.ts",
